   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "from statsmodels.stats.power import TTestIndPower\n",
    "\n",
    "def calculate_required_sample_size(effect_size=0.5, alpha=0.05, power=0.8):\n",
    "    \"\"\"\n",
    "    Menghitung ukuran sampel yang dibutuhkan untuk uji t dua sampel independen.\n",
    "    \n",
    "    Parameter:\n",
    "    ----------\n",
    "    effect_size : float\n",
    "        Cohen's d (0.2=kecil, 0.5=sedang, 0.8=besar).\n",
    "    alpha : float\n",
    "        Tingkat signifikansi.\n",
    "    power : float\n",
    "        Kekuatan statistik yang diinginkan.\n",
    "    \"\"\"\n",
    "    analysis = TTestIndPower()\n",
    "    size = analysis.solve_power(effect_size=effect_size, \n",
    "                                 alpha=alpha, \n",
    "                                 power=power, \n",
    "                                 ratio=1.0, \n",
    "                                 alternative='two-sided')\n",
    "    \n",
    "    print(f\"--- Hasil Power Analysis ---\")\n",
    "    print(f\"Effect Size (Cohen's d): {effect_size}\")\n",
    "    print(f\"Alpha: {alpha}\")\n",
    "    print(f\"Target Power: {power}\")\n",
    "    print(f\"Ukuran Sampel Minimum per Grup: {np.ceil(size)}\")\n",
    "    \n",
    "    return size\n",
    "\n",
    "calculate_required_sample_size()"
   ]
